# ============================
# Visual Studio / .NET ignores
# ============================

# Visual Studio workspace & cache
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.slnx.old

# Build outputs
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Oo]ut/

# MSBuild logs
*.binlog

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml
*.opencover

# NuGet packages (don't commit built packages)
*.nupkg
*.snupkg

# Publish output
publish/
PublishProfiles/

# Benchmark results
BenchmarkDotNet.Artifacts/

# ============================
# IDE-specific
# ============================

# Rider
.idea/
*.DotSettings.user

# VS Code (keep settings.json but ignore others)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ============================
# OS generated files
# ============================
.DS_Store
Thumbs.db
*.swp
*~

# ============================
# Environment & secrets
# ============================
.env
.env.local
.env.*.local
appsettings.*.user.json

# ============================
# Hot Reload
# ============================
*.sarif
